{
  "name": "@patchway/sdk",
  "version": "0.1.0",
  "description": "Framework-agnostic Walrus memory and handoff layer for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "import": "./dist/adapters/ai.js",
      "types": "./dist/adapters/ai.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten-incubation/memwal": "^0.0.6",
    "@mysten/sui": "^2.17.0",
    "@mysten/sui-groups": "^0.0.1",
    "@mysten/sui-stack-messaging": "^0.0.2",
    "@mysten/walrus": "^1.1.7",
    "@supabase/supabase-js": "^2.0.0",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/patchway/patchway"
  }
}
